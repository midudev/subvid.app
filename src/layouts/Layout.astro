---
import "../styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "SubThis Now",
  description = "Transcribe videos in-browser with Whisper + WebGPU and FFmpeg WASM.",
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
